# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
DISCORD_NOTION_CHANNEL_ID=
DISCORD_GITHUB_CHANNEL_ID=

# Optional mentions. Examples: <@&ROLE_ID>, <@USER_ID>, @here
DISCORD_MENTION_ON_NOTION=
DISCORD_MENTION_ON_GITHUB=
DISCORD_NOTION_ASSIGNEE_MENTIONS_JSON={}
DISCORD_GITHUB_REVIEWER_MENTIONS_JSON={}
DISCORD_NOTIFY_ERRORS=true

# Examples:
# DISCORD_NOTION_ASSIGNEE_MENTIONS_JSON={"홍길동":"<@USER_ID>","김철수":"<@&ROLE_ID>"}
# DISCORD_GITHUB_REVIEWER_MENTIONS_JSON={"github-login":"<@USER_ID>","another-login":"<@&ROLE_ID>"}

# Notion
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_POLL_INTERVAL_MS=60000
NOTION_NOTIFY_EXISTING_ON_START=false
NOTION_NOTIFY_REMOVED=false

# Optional Notion property hints. Leave blank to auto-detect.
NOTION_TITLE_PROPERTY=
NOTION_STATUS_PROPERTY=
NOTION_ASSIGNEE_PROPERTY=assign
NOTION_DUE_DATE_PROPERTY=
NOTION_PRIORITY_PROPERTY=

# Optional raw JSON for Notion database query.
# NOTION_QUERY_FILTER_JSON={"property":"Status","status":{"does_not_equal":"Done"}}
# NOTION_QUERY_SORTS_JSON=[{"timestamp":"last_edited_time","direction":"descending"}]

# GitHub
GITHUB_TOKEN=
GITHUB_REPOSITORIES=
GITHUB_POLL_INTERVAL_MS=60000
GITHUB_NOTIFY_EXISTING_ON_START=false
GITHUB_NOTIFY_PR_UPDATES=true

# App
APP_TIMEZONE=Asia/Seoul
DATA_DIR=./data
